{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "sw.js", "use": "@vercel/static" },
    { "src": "manifest.json", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/vapid-public", "dest": "/api/vapid-public.js" },
    { "src": "/api/subscribe", "dest": "/api/subscribe.js" },
    { "src": "/api/notify", "dest": "/api/notify.js" },
    {
      "src": "/sw.js",
      "dest": "/sw.js",
      "headers": { "Service-Worker-Allowed": "/" }
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
